# =====================================================
# BuscaPRO — variáveis globais do monorepo
# Copie para .env (nunca versionar)
# =====================================================

NODE_ENV=development

# ---- API ----
API_PORT=3333
API_URL=http://localhost:3333

# ---- WEB ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# ---- DATABASE (NeonDB) ----
# Formato: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/buscapro?sslmode=require

# ---- AUTH (JWT) ----
JWT_SECRET=troque-este-segredo-por-um-valor-forte-e-aleatorio
JWT_EXPIRES_IN=7d
