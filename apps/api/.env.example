# =====================================================
# apps/api — variáveis Express
# Copie para .env em dev (nunca versionar)
# =====================================================

NODE_ENV=development
API_PORT=3333

# CORS — origem permitida (URL do web)
CORS_ORIGIN=http://localhost:3000

# Banco PostgreSQL (NeonDB — externo)
# Formato: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/buscapro?sslmode=require

# Autenticação JWT
# JWT_SECRET: mín. 16 chars — gere um valor forte (ex.: openssl rand -hex 32)
JWT_SECRET=troque-este-segredo-por-um-valor-forte-e-aleatorio
JWT_EXPIRES_IN=7d

# URL pública desta API (usada para servir uploads locais)
APP_PUBLIC_URL=http://localhost:3333

# =====================================================
# Armazenamento de mídia (avatar / imagem de serviço)
# STORAGE_DRIVER=local  -> salva em ./uploads (dev/demo, sem S3)
# STORAGE_DRIVER=s3     -> S3 compatível (produção)
# =====================================================
STORAGE_DRIVER=local
UPLOAD_DIR=uploads

# Preencha apenas se STORAGE_DRIVER=s3 (AWS S3, Cloudflare R2, MinIO…)
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=buscapro-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://buscapro.com.br
# S3_FORCE_PATH_STYLE=false
