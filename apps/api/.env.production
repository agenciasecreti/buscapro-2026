NODE_ENV=production
API_PORT=3333
CORS_ORIGIN=https://buscapro.com.br
APP_PUBLIC_URL=https://api.buscapro.com.br
# DATABASE_URL e JWT_SECRET injetados pelo secret manager / .env do servidor

# Mídia em produção: use S3 compatível
STORAGE_DRIVER=s3
# S3_ENDPOINT / S3_REGION / S3_BUCKET / S3_ACCESS_KEY_ID
# S3_SECRET_ACCESS_KEY / S3_PUBLIC_URL injetados via secret manager
